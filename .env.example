# ─── Root Environment ─────────────────────────────────────────────
# This file documents shared env vars used across the monorepo.
# Copy the relevant vars into apps/web/.env.docker or apps/api/.env.docker.

# Google OAuth (used at build-time by Next.js)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# JWT Secret (must match between web and api)
JWT_SECRET=change-me-to-a-random-64-char-string
